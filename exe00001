#include <stdio.h>
#include <stdlib.h>
#include <windows.h>
#include <string.h>
#include <ctype.h>

#define MAX_CLIENTES 100

// ===== ESTRUTURA =====
typedef struct {
    int CODIGO;
    char NOME[50];
    char ENDERECO[100];
    char TELEFONE[15];
    char EMAIL[50];
    char CPF[15];
    char DATA_NASC[11];
} CLIENTE;

typedef struct {
    CLIENTE clientes[MAX_CLIENTES];
    int fim;
} LISTA;

// ===== FUNÇÃO GOTOXY =====
// Permite posicionar o cursor na tela
void gotoxy(int x, int y) {
    COORD coord;
    coord.X = x;
    coord.Y = y;
    SetConsoleCursorPosition(GetStdHandle(STD_OUTPUT_HANDLE), coord);
}

// ===== FUNÇÕES AUXILIARES =====

// Limpia buffer de entrada
void limparBuffer() {
    int c;
    while ((c = getchar()) != '\n' && c != EOF);
}

// Lee texto de forma segura evitando desbordamiento
void lerTextoSeguro(char *buffer, int tamanho) {
    fgets(buffer, tamanho, stdin);
    buffer[strcspn(buffer, "\n")] = '\0';
}

// Pausa personalizada
void pausa() {
    gotoxy(5,22);
    system("pause");
}

// Confirma acción antes de ejecutar algo crítico
int confirmarAcao() {
    char op;
    printf("Confirmar (S/N): ");
    scanf(" %c", &op);
    limparBuffer();
    return (op == 'S' || op == 's');
}

// ===== VALIDAÇÕES =====

// Verifica se contém apenas letras
int soLetras(char texto[]) {
    for(int i=0; texto[i] != '\0'; i++)
        if(!isalpha(texto[i]) && texto[i] != ' ')
            return 0;
    return 1;
}

// Verifica se contém apenas números
int soNumeros(char texto[]) {
    for(int i=0; texto[i] != '\0'; i++)
        if(!isdigit(texto[i]))
            return 0;
    return 1;
}

// Validação simples de email
int validarEmail(char email[]) {
    return (strchr(email,'@') && strchr(email,'.'));
}

// Validação de data DD/MM/AAAA
int validarData(char data[]) {
    if(strlen(data) != 10) return 0;
    if(data[2] != '/' || data[5] != '/') return 0;

    for(int i=0;i<10;i++) {
        if(i==2 || i==5) continue;
        if(!isdigit(data[i])) return 0;
    }
    return 1;
}

// ===== INTERFACE NORMAL CENTRALIZADA =====
// Marco limpio sin caracteres especiales

void desenharMarco() {

    system("cls");
    system("color 0A"); // verde normal

    int largura = 80;
    int altura = 25;

    // Bordes verticales
    for(int i = 1; i <= altura; i++) {
        gotoxy(1, i); printf("|");
        gotoxy(largura, i); printf("|");
    }

    // Bordes horizontales
    for(int i = 1; i <= largura; i++) {
        gotoxy(i, 1); printf("-");
        gotoxy(i, 4); printf("-");
        gotoxy(i, 22); printf("-");
        gotoxy(i, 25); printf("-");
    }

    // Esquinas
    gotoxy(1,1); printf("+");
    gotoxy(largura,1); printf("+");
    gotoxy(1,25); printf("+");
    gotoxy(largura,25); printf("+");

    // Titulo centrado
    gotoxy(23,2);
    printf("SISTEMA PROFISSIONAL DE CLIENTES");

    // Subtitulo centrado
    gotoxy(34,3);
    printf("Versao 3.0");

    // Rodape equilibrado
    gotoxy(3,24);
    printf("UNICV - 2026");

    gotoxy(52,24);
    printf("Todos os direitos reservados");
}
// ===== BUSCAR CLIENTE =====
// Retorna posição ou -1 se não existir
int buscarCliente(LISTA *l, int codigo) {
    for(int i=0;i<l->fim;i++)
        if(l->clientes[i].CODIGO == codigo)
            return i;
    return -1;
}

// ===== CADASTRO =====
void cadastrarCliente(LISTA *l) {

    if(l->fim >= MAX_CLIENTES) {
        printf("Limite atingido!");
        pausa();
        return;
    }

    CLIENTE novo;

    desenharMarco();
    gotoxy(5,6); printf("=== CADASTRO ===");

    do {
        gotoxy(5,8); printf("Codigo: ");
        scanf("%d",&novo.CODIGO);
        limparBuffer();
    } while(buscarCliente(l, novo.CODIGO) != -1);

    do {
        gotoxy(5,9); printf("Nome: ");
        lerTextoSeguro(novo.NOME,50);
    } while(!soLetras(novo.NOME));

    gotoxy(5,10); printf("Endereco: ");
    lerTextoSeguro(novo.ENDERECO,100);

    do {
        gotoxy(5,11); printf("Telefone: ");
        lerTextoSeguro(novo.TELEFONE,15);
    } while(!soNumeros(novo.TELEFONE));

    do {
        gotoxy(5,12); printf("Email: ");
        lerTextoSeguro(novo.EMAIL,50);
    } while(!validarEmail(novo.EMAIL));

    do {
        gotoxy(5,13); printf("CPF: ");
        lerTextoSeguro(novo.CPF,15);
    } while(!soNumeros(novo.CPF));

    do {
        gotoxy(5,14); printf("Data Nasc (DD/MM/AAAA): ");
        lerTextoSeguro(novo.DATA_NASC,11);
    } while(!validarData(novo.DATA_NASC));

    l->clientes[l->fim++] = novo;

    gotoxy(5,16);
    printf("Cliente cadastrado com sucesso!");
    pausa();
}

// ===== CONSULTA =====
void consultarCliente(LISTA *l) {

    int codigo;
    desenharMarco();

    gotoxy(5,6); printf("=== CONSULTA ===");
    gotoxy(5,8); printf("Codigo: ");
    scanf("%d",&codigo);
    limparBuffer();

    int pos = buscarCliente(l,codigo);

    if(pos == -1) {
        gotoxy(5,10); printf("Cliente nao encontrado!");
    } else {
        CLIENTE c = l->clientes[pos];
        gotoxy(5,10); printf("Nome: %s", c.NOME);
        gotoxy(5,11); printf("Telefone: %s", c.TELEFONE);
        gotoxy(5,12); printf("Email: %s", c.EMAIL);
        gotoxy(5,13); printf("CPF: %s", c.CPF);
    }
    pausa();
}

// ===== ALTERAÇÃO =====
void alterarCliente(LISTA *l) {

    int codigo;
    desenharMarco();

    gotoxy(5,6); printf("=== ALTERACAO ===");
    gotoxy(5,8); printf("Codigo: ");
    scanf("%d",&codigo);
    limparBuffer();

    int pos = buscarCliente(l,codigo);

    if(pos == -1) {
        gotoxy(5,10); printf("Cliente nao encontrado!");
        pausa();
        return;
    }

    CLIENTE *c = &l->clientes[pos];

    do {
        gotoxy(5,10); printf("Novo Nome: ");
        lerTextoSeguro(c->NOME,50);
    } while(!soLetras(c->NOME));

    gotoxy(5,11); printf("Novo Endereco: ");
    lerTextoSeguro(c->ENDERECO,100);

    gotoxy(5,13);
    printf("Dados atualizados com sucesso!");
    pausa();
}

// ===== EXCLUSÃO =====
void excluirCliente(LISTA *l) {

    int codigo;
    desenharMarco();

    gotoxy(5,6); printf("=== EXCLUSAO ===");
    gotoxy(5,8); printf("Codigo: ");
    scanf("%d",&codigo);
    limparBuffer();

    int pos = buscarCliente(l,codigo);

    if(pos == -1) {
        gotoxy(5,10); printf("Cliente nao encontrado!");
        pausa();
        return;
    }

    gotoxy(5,10);
    if(!confirmarAcao()) {
        printf("Operacao cancelada!");
        pausa();
        return;
    }

    for(int i=pos;i<l->fim-1;i++)
        l->clientes[i] = l->clientes[i+1];

    l->fim--;

    gotoxy(5,12);
    printf("Cliente excluido com sucesso!");
    pausa();
}

// ===== VISUALIZAÇÃO =====
void visualizarClientes(LISTA *l) {

    desenharMarco();
    gotoxy(5,6); printf("=== LISTA DE CLIENTES ===");

    if(l->fim == 0) {
        gotoxy(5,8); printf("Nenhum cliente cadastrado.");
        pausa();
        return;
    }

    int linha = 8;

    for(int i=0;i<l->fim;i++) {
        gotoxy(3,linha++);
        printf("Cod:%d Nome:%s Tel:%s",
               l->clientes[i].CODIGO,
               l->clientes[i].NOME,
               l->clientes[i].TELEFONE);
    }
    pausa();
}

// ===== RELATÓRIOS =====
void relatorios(LISTA *l) {

    int op;

    do {
        desenharMarco();
        gotoxy(35,8); printf("=== RELATORIOS ===");
        gotoxy(35,10); printf("1 - Total de Clientes");
        gotoxy(35,12); printf("2 - Clientes com Gmail");
        gotoxy(35,14); printf("3 - Voltar");

        gotoxy(30,18);
        printf("Opcao: ");
        scanf("%d",&op);
        limparBuffer();

        if(op == 1) {
            gotoxy(30,20);
            printf("Total registrados: %d", l->fim);
            pausa();
        }

        if(op == 2) {
            int contador = 0;
            for(int i=0;i<l->fim;i++)
                if(strstr(l->clientes[i].EMAIL,"gmail"))
                    contador++;

            gotoxy(30,20);
            printf("Clientes com Gmail: %d", contador);
            pausa();
        }

    } while(op != 3);
}

// ===== MENU =====
int menu() {

    int op;

    do {
        desenharMarco();
        gotoxy(30,8); printf("1 - Inclusao");
        gotoxy(30,10); printf("2 - Alteracao");
        gotoxy(30,12); printf("3 - Consulta");
        gotoxy(30,14); printf("4 - Exclusao");
        gotoxy(30,16); printf("5 - Visualizacao");
        gotoxy(30,18); printf("6 - Relatorios");
        gotoxy(30,20); printf("7 - Sair");

        gotoxy(30,22);
        printf("Opcao: ");
        scanf("%d",&op);
        limparBuffer();

    } while(op < 1 || op > 7);

    return op;
}

// ===== MAIN =====
int main() {

    LISTA l;
    l.fim = 0;

    int op;

    do {
        op = menu();

        switch(op) {
            case 1: cadastrarCliente(&l); break;
            case 2: alterarCliente(&l); break;
            case 3: consultarCliente(&l); break;
            case 4: excluirCliente(&l); break;
            case 5: visualizarClientes(&l); break;
            case 6: relatorios(&l); break;
            case 7:
                desenharMarco();
                gotoxy(40,12);
                printf("Encerrando sistema...");
                Sleep(1500);
                break;
        }

    } while(op != 7);

    return 0;
}
